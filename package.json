{
  "name": "geminimock",
  "version": "0.1.2",
  "type": "module",
  "bin": {
    "geminimock": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "main": "dist/cli.js",
  "engines": {
    "node": ">=18.17"
  },
  "scripts": {
    "dev": "bun --watch src/cli.ts serve",
    "start": "bun src/cli.ts serve",
    "auth:login": "bun src/cli.ts auth login",
    "auth:logout": "bun src/cli.ts auth logout",
    "models:list": "bun src/cli.ts models list",
    "self:update": "bun src/cli.ts update",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json && node scripts/prepare-cli-bin.mjs",
    "verify:release": "npm run test && npm run lint && npm run typecheck && npm run build && bun audit && npm audit --omit=dev",
    "check:deps": "npm outdated || true",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "fastify": "^5.7.4",
    "google-auth-library": "^10.6.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.3.2",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
